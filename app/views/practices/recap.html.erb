<h1>Practice recap — <%= @practice.student.name %></h1>
<p>Score: <%= @practice.score %>/10</p>
<hr />
<ol>
  <% @questions.each_with_index do |q, i| %>
    <li class="mb-4">
      <p class="font-semibold">Q<%= i+1 %>: <%= q.question %></p>
      <p>Your answer: <span class="font-medium"><%= q.submitted_answer || "(no answer)" %></span> —
        <% if q.status %>
          <span class="font-semibold text-green-600">Correct</span>
        <% else %>
          <span class="font-semibold text-red-600">Incorrect</span>
        <% end %>
      </p>
      <details class="mt-2">
        <summary class="cursor-pointer underline">Show explanation</summary>
        <div class="mt-2 text-sm text-gray-700">
          <p><strong>Correct answer:</strong> <%= q.correct_answer %></p>
          <p><strong>Explanation:</strong> <%= q.explanation %></p>
        </div>
      </details>
    </li>
  <% end %>
</ol>

<hr class="mt-6" />
<div class="mt-4">
  <%= link_to "Back to student", student_path(@practice.student), class: "inline-block px-4 py-2 bg-blue-600 text-white rounded hover:bg-blue-700" %>
</div>
