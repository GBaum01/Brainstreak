<div class="max-w-2xl mx-auto bg-white p-8 md:p-12 rounded-[2rem] border border-slate-200/60 shadow-sm ring-1 ring-slate-900/5 transition-all duration-300">
  
  <!-- Progress Header -->
  <div class="flex items-center justify-between border-b border-slate-100 pb-4 mb-6">
    <div class="text-sm font-semibold text-slate-500 uppercase tracking-wider">
      Practice Mode
    </div>
    <div class="inline-flex items-center rounded-full bg-indigo-50 px-3 py-1 text-xs font-semibold text-indigo-700 ring-1 ring-inset ring-indigo-700/10">
      Question <%= @position %> of <%= @practice.questions.count %>
    </div>
  </div>

  <!-- Question Heading -->
  <h1 class="text-2xl font-bold tracking-tight text-slate-900 mb-8 pl-0.5">
    <%= @question.question %>
  </h1>

  <div data-controller="question" 
       data-question-practice-id="<%= @practice.id %>" 
       data-question-question-id="<%= @question.id %>" 
       data-question-total-questions="<%= @practice.questions.count %>"
       class="space-y-6">
       
    <!-- Question Input Form -->
    <form id="question-form" data-question-target="form" data-action="submit->question#submit">
      <div class="text-left mb-6">
        <label for="answer_input" class="block text-sm font-medium leading-6 text-slate-900 mb-2 pl-0.5">Your answer</label>
        <div class="relative flex items-center">
          <input id="answer_input" 
                 name="answer" 
                 type="number" 
                 inputmode="numeric" 
                 pattern="[0-9]*" 
                 data-question-target="input" 
                 class="block w-full rounded-lg border-0 py-3 px-4 text-slate-900 shadow-sm ring-1 ring-inset ring-slate-300 placeholder:text-slate-400 focus:ring-2 focus:ring-inset focus:ring-indigo-600 sm:text-sm sm:leading-6 bg-white transition-all duration-200" 
                 placeholder="Enter numbers only..." 
                 required />
        </div>
      </div>
    </form>

    <!-- Submitted Answer State Panel -->
    <div data-question-target="submittedAnswer" style="display:none" class="mb-4 rounded-xl border border-slate-200 bg-slate-50/50 p-5 shadow-inner">
      <p class="text-xs font-semibold text-slate-500 uppercase tracking-wider mb-2 pl-0.5">Submitted answer</p>
      <p class="text-lg font-bold text-slate-900"><span data-question-target="submittedAnswerText"></span></p>
    </div>

    <!-- Result Banner (Correct / Incorrect) -->
    <p data-question-target="result" style="display:none" class="font-bold text-xl mb-4 pl-0.5"></p>

    <!-- Correct Answer Display -->
    <div data-question-target="answer" style="display:none" class="mb-4 p-5 rounded-2xl bg-indigo-50 border border-indigo-100/60 shadow-sm text-left">
      <p class="text-sm font-semibold text-indigo-900/60 uppercase tracking-wider mb-1 pl-0.5">Correct Answer</p>
      <p class="text-lg font-bold text-indigo-700 pl-0.5"><%= @question.correct_answer %></p>
    </div>

    <!-- Explanation Display -->
    <div data-question-target="explanation" style="display:none" class="mb-4 p-5 rounded-2xl bg-slate-50 border border-slate-200/60 shadow-sm text-left">
      <p class="text-sm font-semibold text-slate-500 uppercase tracking-wider mb-2 pl-0.5">Explanation</p>
      <p class="text-base text-slate-600 leading-relaxed pl-0.5"><%= @question.explanation %></p>
    </div>

    <!-- Dynamic Actions Panel -->
    <div class="mt-8 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 border-t border-slate-100 pt-6">
      
      <!-- Primary and Secondary interactive buttons -->
      <div class="flex flex-wrap items-center gap-3">
        <!-- The Dynamic actionBtn: Submit Answer -> Next Question / Submit Practice -->
        <button type="submit" 
                form="question-form" 
                data-question-target="actionBtn" 
                data-action="click->question#handleAction"
                class="rounded-lg bg-indigo-600 px-5 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-indigo-600 cursor-pointer transition-all duration-200 w-full sm:w-auto text-center">
          Submit Answer
        </button>

        <button type="button" 
                data-question-target="explainButton" 
                data-action="click->question#showExplanation" 
                style="display:none" 
                class="rounded-lg bg-slate-100 border border-slate-200 px-5 py-2.5 text-sm font-semibold text-slate-700 hover:bg-slate-200 transition-all duration-200 cursor-pointer w-full sm:w-auto text-center">
          Show explanation
        </button>
      </div>

      <!-- Left / Previous Question Action -->
      <div class="flex items-center gap-3">
        <% if @previous_question %>
          <%= link_to question_path(@previous_question), class: "rounded-lg border border-slate-300 bg-white px-4 py-2.5 text-sm font-semibold text-slate-700 shadow-sm hover:bg-slate-50 transition-all duration-200 text-center w-full sm:w-auto flex items-center justify-center gap-1.5" do %>
            <i class="fa-solid fa-arrow-left"></i> Previous
          <% end %>
        <% end %>
      </div>

      <!-- Hidden trigger components for Stimulus controller execution -->
      <div class="hidden">
        <% if @next_question %>
          <%= link_to "Next", question_path(@next_question), data: { question_target: "nextQuestionBtn" } %>
        <% end %>
        <%= button_to "Submit Practice", submit_practice_path(@practice), method: :post, data: { question_target: "submitPracticeBtn" } %>
      </div>

    </div>
  </div>
</div>
