<p><%= @position %>/<%= @practice.questions.count %></p>

<h1>Question: <%= @question.question %></h1>
<div data-controller="question" data-question-practice-id="<%= @practice.id %>" data-question-question-id="<%= @question.id %>" data-question-total-questions="<%= @practice.questions.count %>" data-question-next-question-url="<%= @next_question ? question_path(@next_question) : "" %>">
  <form data-question-target="form" data-action="submit->question#submit" class="mb-4">
    <label for="answer_input" class="block text-sm font-medium text-gray-700">Your answer</label>
    <div class="mt-1">
      <input id="answer_input" name="answer" type="text" inputmode="decimal" data-question-target="input" class="shadow-sm focus:ring-indigo-500 focus:border-indigo-500 block w-full sm:text-sm border-gray-300 rounded-md" />
    </div>
    <p data-question-target="error" class="mt-1 text-sm text-red-600" style="display:none">Answer must be given as a number</p>
    <div class="mt-2">
      <button type="submit" data-question-target="submit" class="inline-flex items-center px-3 py-2 border border-transparent text-sm leading-4 font-medium rounded-md text-white bg-indigo-600 hover:bg-indigo-500">Submit</button>
    </div>
  </div>

  <!-- Question Heading -->
  <h1 class="text-2xl font-bold tracking-tight text-slate-900 mb-8 pl-0.5">
    <%= @question.question %>
  </h1>

  <div data-controller="question"
       data-question-practice-id="<%= @practice.id %>"
       data-question-question-id="<%= @question.id %>"
       data-question-total-questions="<%= @practice.questions.count %>"
       class="space-y-6">

    <!-- Question Input Form -->
    <form id="question-form" data-question-target="form" data-action="submit->question#submit">
      <div class="text-left mb-6">
        <label for="answer_input" class="block text-sm font-medium leading-6 text-slate-900 mb-2 pl-0.5">Your answer</label>
        <div class="relative flex items-center">
          <input id="answer_input"
                 name="answer"
                 type="number"
                 inputmode="numeric"
                 pattern="[0-9]*"
                 data-question-target="input"
                 class="block w-full rounded-lg border-0 py-3 px-4 text-slate-900 shadow-sm ring-1 ring-inset ring-slate-300 placeholder:text-slate-400 focus:ring-2 focus:ring-inset focus:ring-indigo-600 sm:text-sm sm:leading-6 bg-white transition-all duration-200"
                 placeholder="Enter numbers only..."
                 required />
        </div>
      </div>
    </form>

    <!-- Submitted Answer State Panel -->
    <div data-question-target="submittedAnswer" style="display:none" class="mb-4 rounded-xl border border-slate-200 bg-slate-50/50 p-5 shadow-inner">
      <p class="text-xs font-semibold text-slate-500 uppercase tracking-wider mb-2 pl-0.5">Submitted answer</p>
      <p class="text-lg font-bold text-slate-900"><span data-question-target="submittedAnswerText"></span></p>
    </div>

    <!-- Result Banner (Correct / Incorrect) -->
    <p data-question-target="result" style="display:none" class="font-bold text-xl mb-4 pl-0.5"></p>

  <div class="mt-4 space-x-2">
    <%= button_to "Submit Practice", submit_practice_path(@practice), method: :post, data: { question_target: "submitPracticeBtn" }, class: "inline-flex items-center px-3 py-2 border border-transparent text-sm leading-4 font-medium rounded-md text-white bg-green-600 hover:bg-green-500", style: "display:none" %>
  </div>
</div>
