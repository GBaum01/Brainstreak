<%= render 'layouts/page_header',
           title: "#{@user.username}'s Family Board",
           primary_label: "Add Student",
           primary_path: new_user_student_path(@user) %>

<div class="mt-10">
  <% if @user.students.any? %>
    <!-- Grid Collection Container -->
    <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
      <% @user.students.each do |student| %>
        <!-- Student Card -->
        <div class="relative flex flex-col justify-between rounded-2xl border border-slate-200/60 bg-white p-6 shadow-sm hover:shadow-md transition-shadow duration-200">
          <div>
            <!-- Header Info -->
            <div class="flex items-center gap-x-4">
              <!-- Initial Avatar -->
              <div class="h-12 w-12 rounded-full bg-indigo-50 border border-indigo-100 flex items-center justify-center text-indigo-600 font-bold text-lg">
                <%= student.name[0].upcase %>
              </div>
              <div class="text-left">
                <h3 class="text-lg font-bold leading-7 text-slate-900"><%= student.name %></h3>
                <p class="text-base text-slate-500 font-medium mt-1">
                  <%= student.year_group&.name || "No Year Group" %>
                </p>
              </div>
            </div>
          </div>

          <!-- Bottom Card Actions -->
          <div class="mt-6 flex items-center justify-end gap-x-2 border-t border-slate-100 pt-4">
            <%= link_to "View Student", student_path(student), class: "rounded-lg bg-white px-3.5 py-1.5 text-xs font-semibold text-slate-700 shadow-sm ring-1 ring-inset ring-slate-300 hover:bg-slate-50 transition-colors duration-200" %>
            <%= link_to "Edit", edit_user_student_path(@user, student), class: "rounded-lg bg-white px-3.5 py-1.5 text-xs font-semibold text-slate-700 shadow-sm ring-1 ring-inset ring-slate-300 hover:bg-slate-50 transition-colors duration-200" %>
            <%= link_to "Remove", user_student_path(@user, student), method: :delete, data: { confirm: "Are you sure you want to remove #{student.name}?", turbo_method: :delete }, class: "rounded-lg bg-rose-50 px-3.5 py-1.5 text-xs font-semibold text-rose-600 hover:bg-rose-100 transition-colors duration-200" %>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <!-- Empty State -->
    <div class="text-center py-16 px-4 border-2 border-dashed border-slate-300 rounded-2xl mt-8 bg-white/40">
      <svg class="mx-auto h-12 w-12 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
        <path vector-effect="non-scaling-stroke" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18 9v3m0 0v3m0-3h3m-3 0h-3m-2-5a4 4 0 11-8 0 4 4 0 018 0zM3 20a6 6 0 0112 0v1H3v-1z" />
      </svg>
      <h3 class="mt-4 text-sm font-semibold text-slate-900">No students</h3>
      <p class="mt-1 text-sm text-slate-500">Get started by adding your first student to your family board.</p>
      <div class="mt-6">
        <%= link_to "Add Student", new_user_student_path(@user), class: "inline-flex items-center rounded-lg bg-indigo-600 px-3.5 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500 transition-all duration-200" %>
      </div>
    </div>
  <% end %>
</div>


