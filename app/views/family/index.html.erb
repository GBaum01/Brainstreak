<%= render 'layouts/section_header',
  title: "#{@user.username}'s Family Board",
  button_label: "Add Student",
  button_path: new_user_student_path(@user) %>

<h2>Students</h2>
<% @user.students.each do |student| %>
  <p>
    <strong><%= student.name %></strong><br>
    Year Group: <%= student.year_group&.name %><br>
  <%= link_to "View Student", user_student_path(@user, student) %>
  <%= link_to "Remove",
            user_student_path(@user, student),
            method: :delete,
            data: { confirm: "Are you sure?", turbo_method: :delete } %>
  </p>
<% end %>

<%= link_to "Add Student", new_user_student_path(@user) %>

<hr>

<%= link_to "Log out",
            session_path,
            method: :delete,
            data: { turbo_method: :delete } %>
