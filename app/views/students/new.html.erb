<%= render 'layouts/section_header',
           title: "Add a Student",
           button_label: nil,
           button_path: nil %>

<div class="max-w-2xl mt-10">
  <%= simple_form_for [@user, @student] do |f| %>
    <% if @student.errors.any? %>
      <div class="mb-6 rounded-lg bg-red-50 p-4 border border-red-100 shadow-sm" role="alert">
        <div class="font-semibold mb-2 text-sm text-red-800"><%= pluralize(@student.errors.count, "error") %> prevented this student from being saved:</div>
        <ul class="list-disc pl-5 space-y-1 text-sm text-red-700">
          <% @student.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div class="space-y-6">
      <!-- Student Name using simple_form -->
      <%= f.input :name, required: true, placeholder: "Student's Name", label: "Name" %>

      <!-- Year Group Dropdown Select -->
      <div class="text-left mb-8">
        <%= f.label :year_group_id, "Year Group", class: "block text-sm font-medium leading-6 text-slate-900 mb-2 pl-0.5" %>
        <% if @year_groups.empty? %>
          <div class="mb-3 text-sm font-semibold text-red-600 pl-0.5">
            No year groups are available. Please run <code class="px-1.5 py-0.5 bg-red-50 rounded text-red-700">bin/rails db:seed</code> before creating students.
          </div>
        <% end %>
        <div class="relative flex items-center">
          <%= f.association :year_group, collection: @year_groups, prompt: "Select a year group", label: false, wrapper: false, input_html: { class: "block w-full rounded-lg border-0 py-2.5 px-3.5 text-slate-900 shadow-sm ring-1 ring-inset ring-slate-300 focus:ring-2 focus:ring-inset focus:ring-indigo-600 sm:text-sm sm:leading-6 transition-all duration-200 bg-white appearance-none cursor-pointer", required: true } %>
          <div class="absolute right-4 pointer-events-none text-slate-400 flex items-center">
            <i class="fa-solid fa-chevron-down text-sm"></i>
          </div>
        </div>
      </div>
    </div>

    <!-- Action Bar: Stacked form bottom buttons aligned to the left with border-t -->
    <div class="mt-8 flex items-center justify-start gap-x-4 border-t border-slate-200 pt-6">
      <%= f.button :submit, "Save Student", class: "rounded-lg bg-indigo-600 px-5 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-indigo-600 cursor-pointer transition-all duration-200 text-center" %>
      <%= link_to "Cancel", family_path, class: "rounded-lg border border-slate-300 bg-white px-4 py-2.5 text-sm font-semibold text-slate-700 shadow-sm hover:bg-slate-50 transition-all duration-200 text-center" %>
    </div>
  <% end %>
</div>
