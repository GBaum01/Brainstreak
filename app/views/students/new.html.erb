<h1>Add Student</h1>

<%= form_with model: [@user, @student] do |f| %>
  <div>
    <%= f.label :first_name %><br>
    <%= f.text_field :first_name %>
  </div>

  <div>
    <%= f.label :school_year %><br>
    <%= f.number_field :school_year %>
  </div>

  <div>
    <%= f.submit "Add Student" %>
  </div>
<% end %>
