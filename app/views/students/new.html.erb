<div class="max-w-md mx-auto bg-white p-8 md:p-10 rounded-[2rem] border border-slate-100/80 shadow-[0_15px_50px_-15px_rgba(0,0,0,0.05)] hover:translate-y-[-2px] hover:shadow-[0_20px_60px_-10px_rgba(0,0,0,0.08)] transition-all duration-300">
  <h1 class="font-bold text-3xl text-slate-900 mb-2 text-center">Add a Student</h1>
  <p class="text-sm text-slate-400 mb-8 text-center">Enter their name and select a year group below.</p>

  <%= simple_form_for [@user, @student] do |f| %>
    <% if @student.errors.any? %>
      <div class="mb-6 p-4 text-sm text-rose-800 rounded-2xl bg-rose-50 border border-rose-100 shadow-sm" role="alert">
        <div class="font-semibold mb-2"><%= pluralize(@student.errors.count, "error") %> prevented this student from being saved:</div>
        <ul class="list-disc pl-5 space-y-1">
          <% @student.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <!-- Student Name using simple_form -->
    <%= f.input :name, required: true, placeholder: "Student's Name", label: "Name" %>

    <!-- Year Group Dropdown Select -->
    <div class="text-left mb-8">
      <%= f.label :year_group_id, "Year Group", class: "block text-xs font-semibold text-slate-500 mb-2 pl-1 uppercase tracking-wider" %>
      <% if @year_groups.empty? %>
        <div class="mb-3 text-xs font-semibold text-rose-600 pl-1">
          No year groups are available. Please run <code class="px-1.5 py-0.5 bg-rose-50 rounded text-rose-700">bin/rails db:seed</code> before creating students.
        </div>
      <% end %>
      <div class="relative flex items-center">
        <%= f.association :year_group, collection: @year_groups, prompt: "Select a year group", label: false, wrapper: false, input_html: { class: "w-full px-5 py-4 border border-slate-200 rounded-2xl text-[0.95rem] text-slate-800 bg-white placeholder-slate-400 focus:outline-none focus:border-slate-900 focus:ring-4 focus:ring-slate-100 transition-all duration-200 appearance-none cursor-pointer", required: true } %>
        <div class="absolute right-5 pointer-events-none text-slate-400 flex items-center">
          <i class="fa-solid fa-chevron-down text-sm"></i>
        </div>
      </div>
    </div>

    <!-- Submit Button & Back Link using simple_form button -->
    <div class="space-y-4">
      <%= f.button :submit, "Save Student", class: "w-full py-4 bg-slate-900 hover:bg-slate-800 active:bg-slate-950 text-white font-semibold rounded-2xl flex items-center justify-center gap-2 shadow-md hover:shadow-lg active:shadow-sm transition-all duration-200 cursor-pointer transform active:translate-y-0.5 hover:-translate-y-0.5" %>

      <%= link_to "Back", family_path, class: "block text-center py-3 text-sm text-slate-500 hover:text-slate-900 font-medium transition-colors duration-200 hover:underline" %>
    </div>
  <% end %>
</div>
