  <%= render 'layouts/section_header',
    title: "#{@student.name}'s Streak",
    button_label: nil,
    button_path: nil,
    button_method: nil %>

<h2 class="mt-8 text-2xl font-bold tracking-tight text-slate-900"><%= @student.year_group.name %> - Curriculum</h2>
<%# ---- TOPIC TABS ---- %>
<div class="mt-6" data-controller="tabs">
  <%# Mobile dropdown %>

  <div class="grid grid-cols-1 sm:hidden">
    <select
      aria-label="Select a topic"
      class="col-start-1 row-start-1 w-full appearance-none rounded-md bg-white py-2 pr-8 pl-3 text-base text-gray-900 outline-1 -outline-offset-1 outline-gray-300 focus:outline-2 focus:-outline-offset-2 focus:outline-indigo-600"
      data-action="change->tabs#selectFromDropdown">
      <option value="0">Number and Place Value</option>
      <option value="1">Operations</option>
      <option value="2">Multiplication and Division</option>
      <option value="3">Fractions</option>
    </select>
    <svg viewBox="0 0 16 16" fill="currentColor" aria-hidden="true" class="pointer-events-none col-start-1 row-start-1 mr-2 size-5 self-center justify-self-end fill-gray-500">
      <path d="M4.22 6.22a.75.75 0 0 1 1.06 0L8 8.94l2.72-2.72a.75.75 0 1 1 1.06 1.06l-3.25 3.25a.75.75 0 0 1-1.06 0L4.22 7.28a.75.75 0 0 1 0-1.06Z" clip-rule="evenodd" fill-rule="evenodd" />
    </svg>
  </div>

  <%# Desktop pill tabs %>
  <div class="hidden sm:block">
    <nav aria-label="Topics" class="flex space-x-4">
      <% @student.topics.each_with_index do |topic, index| %>
        <a href="#" data-action="click->tabs#select" data-tabs-target="trigger" data-tabs-index-param="<%= index %>"
          class="rounded-md bg-indigo-100 px-3 py-2 text-medium font-bold text-indigo-700" aria-current="page">
          <%= topic.name %>
        </a>
      <% end %>
    </nav>
  </div>

  <%# Tab panels %>
  <div class="mt-4">
    <% @student.topics.each_with_index do |topic, index| %>
      <% initially_hidden_or_not = index.zero? ? "" : "hidden" %>
      <%# Panel 0 — Number and Place Value %>
      <div data-tabs-target="panel" class="<%= initially_hidden_or_not %>">
        <ul class="divide-y divide-gray-200 rounded-md border border-gray-200">
          <% topic.levels.each do |level| %>
            <li class="flex items-center justify-between px-4 py-1">
              <span class="text-medium font-bold text-gray-900"><%= level.name %></span>
              <%= button_to "Start Practice", level_practices_path(level, student_id: @student.id), method: :post, class: "rounded-md bg-white px-3 py-1.5 text-sm font-medium text-indigo-700 border border-transparent hover:border-indigo-300 hover:bg-white transition-colors duration-200" %>
            </li>
            <%# ---- PRACTICE HISTORY ---- %>
            <div class="pl-6 mt-2">
              <ol class="mt-2 space-y-1">
                <% @student.practices.order(:created_at).each_with_index do |practice, index| %>
                <li class="text-sm text-gray-700">
                  Practice <%= index + 1 %> — <%= practice.score %>/10 |
                  <%= link_to "View Recap", recap_practice_path(practice), class: "text-indigo-600 hover:underline" %>
                </li>
                <% end %>
              </ol>
            </div>
          <% end %>
        </ul>
      </div>
    <% end %>
  </div>
</div>

<%# ---- PRACTICE HISTORY ---- %>
<div class="mt-8">

  <%= render 'layouts/page_header',
    title: "#{@student.name}'s Streak" %>

  <ol class="mt-2 space-y-1">
    <% @student.practices.order(:created_at).each_with_index do |practice, index| %>
     <li class="text-sm text-gray-700">
      Practice <%= index + 1 %> — <%= practice.score %>/10 |
      <%= link_to "View Recap", recap_practice_path(practice), class: "text-indigo-600 hover:underline" %>
     </li>


    <% end %>
  </ol>
</div>
