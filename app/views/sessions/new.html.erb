<div class="bg-slate-50 min-h-screen flex flex-col justify-between font-sans text-slate-800">
  <!-- Minimalist Navbar -->
  <nav class="flex justify-between items-center px-6 py-6 md:px-12 bg-transparent">
    <a href="/" class="font-bold text-xl text-slate-900 tracking-tight hover:opacity-80 transition-opacity duration-200">Brainstreak</a>
    <button type="button" class="bg-transparent border-0 text-slate-500 hover:text-slate-900 text-lg cursor-pointer transition-all duration-200 hover:scale-105" aria-label="Change Language">
      <i class="fa-solid fa-globe"></i>
    </button>
  </nav>

  <!-- Login Card Container -->
  <main class="flex-grow flex items-center justify-center px-6 py-12">
    <div class="bg-white w-full max-w-md p-8 md:p-10 rounded-[2rem] border border-slate-100/80 shadow-[0_15px_50px_-15px_rgba(0,0,0,0.05)] hover:translate-y-[-2px] hover:shadow-[0_20px_60px_-10px_rgba(0,0,0,0.08)] transition-all duration-300 text-center">
      <h1 class="font-bold text-3xl md:text-4xl text-slate-900 mb-2">Hello Again!</h1>
      <p class="text-base text-slate-400 mb-8 font-normal">Welcome Back You've Been Missed!</p>

      <%= simple_form_for :login, url: session_path, method: :post do |f| %>
        <%= f.input :login, required: true, placeholder: "Email or Username", label: "Username or Email", input_html: { name: :login, autocomplete: "username" } %>

        <!-- Password Input with Absolute Toggle Button Overlay -->
        <div class="text-left mb-5">
          <%= f.label :password, class: "block text-sm font-medium leading-6 text-slate-900 mb-2 pl-0.5" %>
          <div class="relative flex items-center">
            <%= f.input_field :password, name: :password, id: "login-password-field", class: "block w-full rounded-lg border-0 py-2.5 px-3.5 text-slate-900 shadow-sm ring-1 ring-inset ring-slate-300 placeholder:text-slate-400 focus:ring-2 focus:ring-inset focus:ring-indigo-600 sm:text-sm sm:leading-6 transition-all duration-200 bg-white", placeholder: "Password", required: true, autocomplete: "current-password" %>
            <button type="button" class="absolute right-4 bg-transparent border-none text-slate-400 hover:text-slate-600 cursor-pointer text-base flex items-center transition-colors duration-200" id="password-toggle-trigger" onclick="togglePasswordVisibility()" aria-label="Toggle password visibility">
              <i class="fa-solid fa-eye-slash" id="password-toggle-icon"></i>
            </button>
          </div>
        </div>

        <!-- Recovery Password Link -->
        <div class="text-right -mt-2 mb-8">
          <a href="#" class="text-xs text-slate-500 hover:text-slate-900 underline font-medium transition-colors duration-200">Recovery Password</a>
        </div>

        <!-- Submit Button using simple_form button -->
        <%= f.button :submit, "Sign In", class: "w-full py-4 bg-slate-900 hover:bg-slate-800 active:bg-slate-950 text-white font-semibold rounded-2xl flex items-center justify-center gap-2 shadow-md hover:shadow-lg active:shadow-sm transition-all duration-200 cursor-pointer transform active:translate-y-0.5 hover:-translate-y-0.5" %>

        <!-- Sign Up Link -->
        <div class="text-sm text-slate-400 mt-6">
          Don't have an Account? 
          <%= link_to "SIGN UP", new_user_path, class: "text-slate-900 font-bold hover:opacity-80 underline transition-opacity duration-200" %>
        </div>
      <% end %>
    </div>
  </main>
</div>

<!-- Password Visibility Toggle Script -->
<script>
  function togglePasswordVisibility() {
    const passwordField = document.getElementById('login-password-field');
    const toggleIcon = document.getElementById('password-toggle-icon');
    
    if (passwordField.type === 'password') {
      passwordField.type = 'text';
      toggleIcon.classList.remove('fa-eye-slash');
      toggleIcon.classList.add('fa-eye');
    } else {
      passwordField.type = 'password';
      toggleIcon.classList.remove('fa-eye');
      toggleIcon.classList.add('fa-eye-slash');
    }
  }
</script>
