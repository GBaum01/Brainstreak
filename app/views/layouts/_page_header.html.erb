<%# app/views/layouts/_page_header.html.erb %>
<div class="sticky -top-8 -mt-8 pt-8 z-30 bg-white pb-4 border-b border-slate-200/80 mb-6">
  <% if local_assigns[:back_path] %>
    <div class="mb-3">
      <%= link_to back_path, class: "inline-flex items-center gap-1.5 text-sm font-semibold text-slate-500 hover:text-slate-800 transition-colors duration-200" do %>
        <i class="fa-solid fa-arrow-left"></i> <%= local_assigns[:back_label] || "Back" %>
      <% end %>
    </div>
  <% end %>

  <div class="sm:flex sm:items-center sm:justify-between">
    <h1 class="text-3xl font-bold tracking-tight text-slate-900"><%= title %></h1>
    
    <div class="mt-3 sm:mt-0 sm:ml-4 flex flex-wrap items-center gap-3">
      <%# --- Borderless Button --- %>
      <% if local_assigns[:borderless_label] && local_assigns[:borderless_path] %>
        <% if local_assigns[:borderless_method] == :post %>
          <%= button_to borderless_label, borderless_path, method: :post, class: "inline-flex items-center text-sm font-semibold text-slate-600 hover:text-slate-900 transition-all duration-200 cursor-pointer bg-transparent border-0" %>
        <% else %>
          <%= link_to borderless_label, borderless_path, class: "inline-flex items-center text-sm font-semibold text-slate-600 hover:text-slate-900 transition-all duration-200 cursor-pointer" %>
        <% end %>
      <% end %>

      <%# --- Secondary Button --- %>
      <% if local_assigns[:secondary_label] && local_assigns[:secondary_path] %>
        <% if local_assigns[:secondary_method] == :post %>
          <%= button_to secondary_label, secondary_path, method: :post, class: "inline-flex items-center rounded-lg border border-slate-300 bg-white px-4 py-2 text-sm font-semibold text-slate-700 shadow-sm hover:bg-slate-50 transition-all duration-200 cursor-pointer" %>
        <% else %>
          <%= link_to secondary_label, secondary_path, class: "inline-flex items-center rounded-lg border border-slate-300 bg-white px-4 py-2 text-sm font-semibold text-slate-700 shadow-sm hover:bg-slate-50 transition-all duration-200 cursor-pointer" %>
        <% end %>
      <% end %>

      <%# --- Primary Button --- %>
      <% if local_assigns[:primary_label] && local_assigns[:primary_path] %>
        <% if local_assigns[:primary_method] == :post %>
          <%= button_to primary_label, primary_path, method: :post, class: "inline-flex items-center rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-indigo-600 transition-all duration-200 cursor-pointer border-0" %>
        <% else %>
          <%= link_to primary_label, primary_path, class: "inline-flex items-center rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-indigo-600 transition-all duration-200 cursor-pointer" %>
        <% end %>
      <% end %>

      <%# --- Backward Compatibility for old button_label / button_path --- %>
      <% if local_assigns[:button_label] && local_assigns[:button_path] %>
        <% button_method = local_assigns[:button_method] || :get %>
        <% if button_method == :post %>
          <%= button_to button_label, button_path, method: :post, class: "inline-flex items-center rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-indigo-600 transition-all duration-200 cursor-pointer border-0" %>
        <% else %>
          <%= link_to button_label, button_path, class: "inline-flex items-center rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-indigo-600 transition-all duration-200 cursor-pointer" %>
        <% end %>
      <% end %>
    </div>
  </div>
</div>
